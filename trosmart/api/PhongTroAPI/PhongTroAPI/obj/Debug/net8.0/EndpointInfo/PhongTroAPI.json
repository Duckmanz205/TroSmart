  "components": {
    "schemas": {
      "CoSoUpsertDto": {
        "type": "object",
        "properties": {
          "tenCoSo": {
            "type": "string",
            "nullable": true
          },
          "diaChi": {
            "type": "string",
            "nullable": true
          },
          "loaiHinh": {
            "type": "string",
            "nullable": true
          },
          "moTa": {
            "type": "string",
            "nullable": true
          },
          "maQuanLy": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "latitude": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "maTienIchIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PhongUpsertDto": {
        "required": [
          "maCoSo",
          "soPhong",
          "trangThai"
        ],
        "type": "object",
        "properties": {
          "maCoSo": {
            "type": "integer",
            "format": "int32"
          },
          "soPhong": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "tang": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "dienTich": {
            "maximum": 10000,
            "minimum": 0.01,
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "giaThue": {
            "maximum": 999999999,
            "minimum": 1,
            "type": "number",
            "format": "double"
          },
          "soNguoiToiDa": {
            "maximum": 50,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "trangThai": {
            "minLength": 1,
            "pattern": "^(Trống|Đang thuê|Bảo trì)$",
            "type": "string"
          },
          "moTa": {
            "maxLength": 1000,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "maTienIchIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TienIchCreateDto": {
        "type": "object",
        "properties": {
          "tenTienIch": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
